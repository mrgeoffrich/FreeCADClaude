<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<package format="1" xmlns="https://wiki.freecad.org/Package_Metadata">
  <name>FreeCADClaude</name>
  <description>A dockable chat panel that lets you talk to Claude with access to FreeCAD's internals. Unofficial — not affiliated with or endorsed by Anthropic.</description>
  <version>0.1.0</version>
  <date>2026-06-26</date>
  <maintainer email="geoff.rich@gmail.com">Geoff Rich</maintainer>
  <license file="LICENSE">LGPL-2.1-or-later</license>
  <url type="repository" branch="main">https://github.com/mrgeoffrich/FreeCADClaude</url>
  <url type="readme">https://raw.githubusercontent.com/mrgeoffrich/FreeCADClaude/main/README.md</url>
  <url type="bugtracker">https://github.com/mrgeoffrich/FreeCADClaude/issues</url>
  <icon>freecad/freecadclaude/resources/icon.svg</icon>
  <content>
    <workbench>
      <classname>FreeCADClaudeWorkbench</classname>
      <name>Claude Chat</name>
      <!-- InitGui.py lives at the addon root, not in a per-workbench subdir.
           Without this, FreeCAD looks in a phantom "Claude Chat" folder,
           finds no InitGui.py, and skips the workbench. -->
      <subdirectory>.</subdirectory>
      <description>Talk to Claude with access to FreeCAD.</description>
      <icon>freecad/freecadclaude/resources/icon.svg</icon>
      <tag>AI</tag>
      <tag>assistant</tag>
      <tag>chat</tag>
      <tag>automation</tag>
      <freecadmin>1.1.0</freecadmin>
    </workbench>
  </content>
</package>
