<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<package format="1" xmlns="https://wiki.freecad.org/Package_Metadata">
  <name>ClaudeChat</name>
  <description>A dockable chat panel that lets you talk to Claude with access to FreeCAD's internals.</description>
  <version>0.1.0</version>
  <date>2026-06-26</date>
  <maintainer email="geoff.rich@gmail.com">Geoff Rich</maintainer>
  <license file="LICENSE">LGPL-2.1-or-later</license>
  <url type="repository" branch="main">https://github.com/mrgeoffrich/ClaudeChat</url>
  <icon>freecad/claudechat/resources/icon.svg</icon>
  <content>
    <workbench>
      <classname>ClaudeChatWorkbench</classname>
      <name>Claude Chat</name>
      <!-- InitGui.py lives at the addon root, not in a per-workbench subdir.
           Without this, FreeCAD looks in a phantom "Claude Chat" folder,
           finds no InitGui.py, and skips the workbench. -->
      <subdirectory>.</subdirectory>
      <description>Talk to Claude with access to FreeCAD.</description>
      <icon>freecad/claudechat/resources/icon.svg</icon>
    </workbench>
  </content>
</package>
